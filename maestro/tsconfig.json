{
  "compilerOptions": {
    "target": "ES2020",
    "module": "Node16",
    "moduleResolution": "Node16",
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "skipLibCheck": true,
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["fixtures/**/*.ts", "scripts/**/*.ts", "utils/**/*.ts"],
  "exclude": ["fixtures/calls_seed.ts"]
}
