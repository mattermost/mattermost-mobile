{
  "name": "mattermost-mobile-maestro",
  "version": "1.0.0",
  "description": "Maestro system-level E2E tests for Mattermost Mobile",
  "scripts": {
    "check": "tsc --noEmit",
    "test:ios": "maestro test --platform ios flows/",
    "test:android": "maestro test --platform android flows/",
    "dry-run": "maestro test --dry-run flows/",
    "validate-headers": "bash scripts/validate-flow-headers.sh"
  },
  "devDependencies": {
    "@types/node": "20.0.0",
    "axios": "1.8.4",
    "tsx": "4.0.0"
  }
}
